---
import Layout from "../layouts/Layout.astro";
import { aProposIntro, aProposSections } from "../data/site.js";

const icones = { school: "🎓", briefcase: "💼", heart: "❤", default: "▸" };
---

<Layout titrePage="À propos — Portfolio">
  <section>
    <div class="container">
      <h1 class="section-titre reveal">À propos</h1>
      <p class="intro reveal">{aProposIntro}</p>

      <div class="sections">
        {aProposSections.map((s, i) => (
          <div class="depliable reveal">
            <button class="depliable-tete" data-cible={`sec-${i}`}>
              <span class="depliable-titre">
                <span class="depliable-icone">{icones[s.icone] || icones.default}</span>
                {s.titre}
              </span>
              <span class="depliable-fleche" id={`fleche-${i}`}>+</span>
            </button>
            <div class="depliable-corps" id={`sec-${i}`}>
              <ul>{s.items.map((item) => <li>{item}</li>)}</ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .intro { max-width: 760px; color: var(--texte-doux); font-size: 1.08rem; margin-bottom: 2.5rem; }
  .sections { display: flex; flex-direction: column; gap: 1rem; max-width: 760px; }
  .depliable { border: 1px solid var(--bordure); border-radius: var(--rayon); background: var(--bg-carte); overflow: hidden; }
  .depliable-tete {
    width: 100%; display: flex; justify-content: space-between; align-items: center;
    padding: 1.2rem 1.5rem; background: none; border: none; cursor: pointer;
    color: var(--texte); font-size: 1.05rem; font-weight: 600; font-family: inherit;
    transition: background var(--transition);
  }
  .depliable-tete:hover { background: var(--bg-alt); }
  .depliable-titre { display: flex; align-items: center; gap: 0.7rem; color: var(--bleu); }
  .depliable-icone { font-size: 1.1rem; }
  .depliable-fleche { color: var(--ambre); font-size: 1.4rem; font-weight: 400; transition: transform var(--transition); }
  .depliable-corps {
    max-height: 0; overflow: hidden; transition: max-height 0.3s ease;
  }
  .depliable-corps ul { list-style: none; padding: 0 1.5rem 1.3rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .depliable-corps li {
    font-size: 0.95rem; color: var(--texte-doux); padding-left: 1.2rem; position: relative;
  }
  .depliable-corps li::before { content: "▸"; position: absolute; left: 0; color: var(--ambre); }
</style>

<script>
  document.querySelectorAll(".depliable-tete").forEach((tete) => {
    tete.addEventListener("click", () => {
      const cibleId = tete.getAttribute("data-cible");
      const corps = document.getElementById(cibleId);
      const fleche = tete.querySelector(".depliable-fleche");
      const ouvert = corps.style.maxHeight && corps.style.maxHeight !== "0px";
      if (ouvert) {
        corps.style.maxHeight = "0px";
        fleche.textContent = "+";
        fleche.style.transform = "rotate(0deg)";
      } else {
        corps.style.maxHeight = corps.scrollHeight + "px";
        fleche.textContent = "−";
      }
    });
  });
</script>
