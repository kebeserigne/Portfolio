---
import Layout from "../layouts/Layout.astro";
import { projets } from "../data/site.js";
---

<Layout titrePage="Projets — Portfolio">
  <section>
    <div class="container">
      <h1 class="section-titre reveal">Projets</h1>
      <p class="section-sous-titre reveal">
        Une sélection de mes réalisations techniques, professionnelles et personnelles.
      </p>

      <div class="grille">
        {projets.map((p) => (
          <article class="carte reveal">
            <div class="img-zone">
              {p.image ? (
                <img src={p.image} alt={p.titre} />
              ) : (
                <div class="img-placeholder">{p.titre}</div>
              )}
            </div>
            <div class="corps">
              <h3 class="titre">{p.titre}</h3>
              {p.type && <span class="type">{p.type}</span>}
              <p class="desc">{p.description}</p>

              <div class="liens-ext">
                {p.lien && <a href={p.lien} target="_blank" rel="noopener">Voir le projet →</a>}
                {p.github && <a href={p.github} target="_blank" rel="noopener">GitHub</a>}
              </div>

              <div class="techs">
                {p.techs.map((t) => <span class="tag">{t}</span>)}
              </div>

              {p.motsCles && p.motsCles.length > 0 && (
                <div class="mots">
                  {p.motsCles.map((m) => <span class="mot">{m}</span>)}
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .grille { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem; }
  .carte {
    background: var(--bg-carte); border: 1px solid var(--bordure);
    border-radius: var(--rayon); overflow: hidden; display: flex; flex-direction: column;
    transition: transform var(--transition), border-color var(--transition);
  }
  .carte:hover { transform: translateY(-4px); border-color: var(--ambre); }
  .img-zone { height: 160px; background: var(--bg-alt); }
  .img-zone img { width: 100%; height: 100%; object-fit: cover; }
  .img-placeholder {
    width: 100%; height: 100%; display: grid; place-items: center;
    color: var(--texte-doux); font-weight: 600; padding: 1rem; text-align: center;
    background: linear-gradient(135deg, rgba(74,143,212,0.15), rgba(245,166,35,0.1));
  }
  .corps { padding: 1.4rem; display: flex; flex-direction: column; flex-grow: 1; }
  .titre { color: var(--bleu); font-size: 1.15rem; margin-bottom: 0.3rem; }
  .type { font-size: 0.78rem; color: var(--ambre); font-weight: 600; margin-bottom: 0.7rem; }
  .desc { color: var(--texte-doux); font-size: 0.92rem; margin-bottom: 1rem; flex-grow: 1; }
  .liens-ext { display: flex; gap: 1rem; margin-bottom: 1rem; }
  .liens-ext a { color: var(--ambre); font-size: 0.88rem; font-weight: 600; }
  .techs { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 0.8rem; }
  .tag {
    font-size: 0.76rem; padding: 0.25rem 0.7rem; border-radius: 999px;
    background: rgba(74,143,212,0.15); color: var(--bleu-clair); font-weight: 600;
  }
  .mots { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .mot {
    font-size: 0.76rem; padding: 0.25rem 0.7rem; border-radius: 999px;
    background: rgba(245,166,35,0.15); color: var(--ambre-clair); font-weight: 600;
  }
</style>
