---
import Layout from "../layouts/Layout.astro";
import { profil } from "../data/site.js";
const acces = [
  { nom: "En savoir plus sur moi", lien: "/a-propos", icone: "👤" },
  { nom: "Découvrir mes compétences", lien: "/competences", icone: "⚡" },
  { nom: "Projets académiques", lien: "/saes", icone: "📚" },
  { nom: "Expériences professionnelles", lien: "/experiences", icone: "💼" },
  { nom: "Explorer mes projets", lien: "/projets", icone: "🚀" },
  { nom: "Me contacter", lien: "/contact", icone: "✉" },
];
---
<Layout>
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-photo reveal">
        {profil.photo ? (
          <img src={profil.photo} alt={`Photo de ${profil.nom}`} />
        ) : (
          <div class="photo-placeholder">Ta photo</div>
        )}
      </div>
      <h1 class="hero-nom reveal">{profil.nom}</h1>
      <p class="hero-titre reveal">{profil.titre}</p>
      <p class="hero-accroche reveal">{profil.accroche}</p>
    </div>
  </section>
  <section class="acces">
    <div class="container">
      <div class="acces-grille">
        {acces.map((a) => (
          <a href={a.lien} class="acces-bouton reveal">
            <span class="acces-icone">{a.icone}</span>
            <span class="acces-nom">{a.nom}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
<style>
  .hero {
    padding: 4rem 0 2rem;
    text-align: center;
    background: radial-gradient(circle at 50% 0%, rgba(45, 212, 191, 0.14), transparent 55%);
  }
  .hero-inner { display: flex; flex-direction: column; align-items: center; }
  .hero-photo { margin-bottom: 1.5rem; }
  .hero-photo img, .photo-placeholder {
    width: 150px; height: 150px; border-radius: 50%;
    object-fit: cover; padding: 4px;
    background: linear-gradient(135deg, var(--bleu), var(--menthe));
    box-shadow: 0 10px 35px var(--ombre-menthe);
  }
  .photo-placeholder { display: grid; place-items: center; color: white; font-weight: 600; font-size: 0.85rem; }

  .hero-nom {
    font-size: clamp(2.2rem, 6vw, 3.4rem);
    background: linear-gradient(135deg, var(--bleu), var(--menthe));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: 0.4rem;
  }
  .hero-titre {
    font-size: clamp(1rem, 3vw, 1.3rem);
    color: var(--texte-doux);
    font-weight: 600;
    margin-bottom: 1.2rem;
  }
  .hero-accroche {
    max-width: 600px;
    color: var(--texte-doux);
    font-size: 1.05rem;
  }

  .acces { padding-top: 1rem; }
  .acces-grille {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.2rem;
    max-width: 760px;
    margin: 0 auto;
  }
  .acces-bouton {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.3rem 1.5rem;
    border-radius: 16px;
    background: var(--bg-carte);
    border: 1px solid var(--bordure);
    box-shadow: 0 4px 20px var(--ombre);
    transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
  }
  .acces-bouton:hover {
    transform: translateY(-4px);
    border-color: var(--menthe);
    box-shadow: 0 20px 50px var(--ombre-menthe);
  }
  .acces-icone {
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    display: grid;
    place-items: center;
    border-radius: 10px;
    background: rgba(45, 212, 191, 0.12);
    font-size: 1.3rem;
  }
  .acces-bouton:hover .acces-icone {
    background: var(--menthe);
  }
  .acces-nom {
    font-weight: 600;
    font-size: 1rem;
    color: var(--bleu);
  }

  @media (max-width: 600px) {
    .acces-grille { grid-template-columns: 1fr; }
  }
</style>
