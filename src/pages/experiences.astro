---
import Layout from "../layouts/Layout.astro";
import { experiences } from "../data/site.js";
---

<Layout titrePage="Expériences pro — Portfolio">
  <section>
    <div class="container">
      <h1 class="section-titre reveal">Expériences pro</h1>
      <p class="section-sous-titre reveal">Mon stage et mon alternance.</p>
      <div class="timeline">
        {experiences.map((exp) => (
          <div class="exp reveal">
            <div class="point" />
            <div class="contenu">
              <div class="entete">
                <h3 class="poste">{exp.poste}</h3>
                <span class="periode">{exp.periode}</span>
              </div>
              <p class="structure">{exp.structure}</p>
              <p class="desc">{exp.description}</p>
              <div class="techs">{exp.techs.map((t) => <span class="tag">{t}</span>)}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .timeline { position: relative; padding-left: 1.5rem; max-width: 800px; }
  .timeline::before {
    content: ""; position: absolute; left: 5px; top: 6px; bottom: 6px;
    width: 2px; background: linear-gradient(var(--bleu), var(--ambre));
  }
  .exp { position: relative; padding-bottom: 2.5rem; }
  .exp:last-child { padding-bottom: 0; }
  .point {
    position: absolute; left: -1.5rem; top: 6px; width: 12px; height: 12px;
    border-radius: 50%; background: var(--ambre); border: 3px solid var(--bg);
  }
  .contenu {
    background: var(--bg-carte); border: 1px solid var(--bordure);
    border-radius: var(--rayon); padding: 1.5rem;
  }
  .entete { display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 0.5rem; }
  .poste { color: var(--bleu); font-size: 1.1rem; }
  .periode { font-size: 0.85rem; color: var(--ambre); font-weight: 600; }
  .structure { color: var(--texte-doux); font-weight: 600; font-size: 0.95rem; margin: 0.2rem 0 0.7rem; }
  .desc { color: var(--texte-doux); font-size: 0.92rem; margin-bottom: 1rem; }
  .techs { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .tag {
    font-size: 0.76rem; padding: 0.25rem 0.7rem; border-radius: 999px;
    background: rgba(245,166,35,0.15); color: var(--ambre-clair); font-weight: 600;
  }
</style>
