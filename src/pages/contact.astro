---
import Layout from "../layouts/Layout.astro";
import { profil } from "../data/site.js";
---

<Layout titrePage="Contact — Portfolio">
  <section>
    <div class="container">
      <h1 class="section-titre reveal">Contact</h1>
      <p class="section-sous-titre reveal">Une question, une opportunité ? Contactez-moi.</p>

      <div class="grille">
        <div class="liens reveal">
          <a href={`mailto:${profil.email}`} class="lien-direct">
            <span class="icone">✉</span>
            <div><strong>Email</strong><span>{profil.email}</span></div>
          </a>
          <a href={profil.linkedin} target="_blank" rel="noopener" class="lien-direct">
            <span class="icone">in</span>
            <div><strong>LinkedIn</strong><span>Voir mon profil</span></div>
          </a>
          <a href={profil.github} target="_blank" rel="noopener" class="lien-direct">
            <span class="icone">{"</>"}</span>
            <div><strong>GitHub</strong><span>Voir mon code</span></div>
          </a>
        </div>

        <form class="form" action="https://formspree.io/f/TON_ID" method="POST" id="form-contact">
          <label>Nom<input type="text" name="nom" required placeholder="Votre nom" /></label>
          <label>Email<input type="email" name="email" required placeholder="exemple@gmail.com" /></label>
          <label>Message<textarea name="message" rows="4" required placeholder="Votre message..."></textarea></label>
          <button type="submit" class="btn btn-plein">Envoyer</button>
          <p class="info" id="form-info"></p>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style>
  .grille { display: grid; grid-template-columns: 1fr 1.3fr; gap: 2.5rem; }
  @media (max-width: 720px) { .grille { grid-template-columns: 1fr; } }
  .liens { display: flex; flex-direction: column; gap: 1rem; }
  .lien-direct {
    display: flex; align-items: center; gap: 1rem; padding: 1rem 1.2rem;
    border: 1px solid var(--bordure); border-radius: var(--rayon); background: var(--bg-carte);
    transition: transform var(--transition), border-color var(--transition);
  }
  .lien-direct:hover { transform: translateX(4px); border-color: var(--ambre); }
  .lien-direct .icone {
    width: 42px; height: 42px; flex-shrink: 0; display: grid; place-items: center;
    border-radius: 10px; background: linear-gradient(135deg, var(--bleu), var(--ambre));
    color: #0f1825; font-weight: 700;
  }
  .lien-direct div { display: flex; flex-direction: column; }
  .lien-direct strong { font-size: 0.95rem; }
  .lien-direct span { font-size: 0.85rem; color: var(--texte-doux); }
  .form { display: flex; flex-direction: column; gap: 1rem; }
  .form label { display: flex; flex-direction: column; gap: 0.4rem; font-size: 0.9rem; font-weight: 600; color: var(--texte-doux); }
  .form input, .form textarea {
    padding: 0.7rem 0.9rem; border: 1px solid var(--bordure); border-radius: 10px;
    background: var(--bg-carte); color: var(--texte); font-family: inherit; font-size: 0.95rem;
    transition: border-color var(--transition);
  }
  .form input:focus, .form textarea:focus { outline: none; border-color: var(--ambre); }
  .form button { align-self: flex-start; }
  .info { font-size: 0.9rem; font-weight: 600; }
</style>

<script>
  const form = document.getElementById("form-contact");
  const info = document.getElementById("form-info");
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      info.textContent = "Envoi en cours...";
      info.style.color = "var(--texte-doux)";
      try {
        const r = await fetch(form.action, {
          method: "POST", body: new FormData(form), headers: { Accept: "application/json" },
        });
        if (r.ok) {
          info.textContent = "✅ Message envoyé, merci !";
          info.style.color = "var(--ambre)";
          form.reset();
        } else {
          info.textContent = "❌ Une erreur est survenue. Réessaie.";
          info.style.color = "#e85d5d";
        }
      } catch {
        info.textContent = "❌ Pas de connexion. Réessaie plus tard.";
        info.style.color = "#e85d5d";
      }
    });
  }
</script>
